# =============================================================================
# Flash Sale Platform — Local environment variables
# Copy this file to .env and adjust as needed.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=flashsale
POSTGRES_PASSWORD=flashsale_dev

# ---------------------------------------------------------------------------
# Redis Cluster
# ---------------------------------------------------------------------------
REDIS_PASSWORD=redis_dev

# Spring application config (used by services connecting to Redis Cluster)
# Comma-separated list of all 6 nodes — Lettuce discovers the rest via CLUSTER NODES
SPRING_DATA_REDIS_CLUSTER_NODES=localhost:7001,localhost:7002,localhost:7003

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
# Services inside docker network use the INTERNAL listener
KAFKA_BOOTSTRAP_SERVERS_INTERNAL=kafka:29092
# Local JVM processes (tests, local service runs) use the EXTERNAL listener
KAFKA_BOOTSTRAP_SERVERS_EXTERNAL=localhost:9092

# ---------------------------------------------------------------------------
# ClickHouse
# ---------------------------------------------------------------------------
CLICKHOUSE_USER=flashsale
CLICKHOUSE_PASSWORD=flashsale_dev
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123

# ---------------------------------------------------------------------------
# Spring datasource URLs (for running services locally against docker infra)
# ---------------------------------------------------------------------------
SALE_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/sales_db
INVENTORY_SERVICE_DB_URL=jdbc:postgresql://localhost:5433/inventory_db
ORDER_SERVICE_DB_URL=jdbc:postgresql://localhost:5434/orders_db

# ---------------------------------------------------------------------------
# Service ports (for local runs outside Docker)
# ---------------------------------------------------------------------------
SALE_SERVICE_PORT=8081
INVENTORY_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
ANALYTICS_SERVICE_PORT=8085
